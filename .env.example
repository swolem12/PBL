# === Firebase (client SDK — baked into the build; safe public Web config) ===
# Project: https://console.firebase.google.com/project/pickleleauge
# Fill in from Firebase Console → Project Settings → General → Your apps (Web).
NEXT_PUBLIC_FIREBASE_API_KEY=""
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN="pickleleauge.firebaseapp.com"
NEXT_PUBLIC_FIREBASE_PROJECT_ID="pickleleauge"
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET="pickleleauge.firebasestorage.app"
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID="481849102562"
NEXT_PUBLIC_FIREBASE_APP_ID=""

# === Firebase App Check (reCAPTCHA Enterprise) ===
# Required once Cloud Functions are deployed with enforceAppCheck: true.
# 1. Firebase Console → App Check → Apps → Web app → Register with reCAPTCHA Enterprise
# 2. Copy the site key here.
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=""

# Local development override: set to "true" to mint an App Check debug token
# (printed in the browser console on first load). Paste the token into
# Firebase Console → App Check → Apps → ⋯ → Manage debug tokens to make
# this browser accepted by enforced backends.
NEXT_PUBLIC_APPCHECK_DEBUG=""

# Local development override: set to "true" to route all callables at the
# Functions emulator on http://127.0.0.1:5001 instead of production.
NEXT_PUBLIC_FUNCTIONS_EMULATOR=""

# === Admin seed script only — NEVER commit. Paste the JSON service account. ===
# Generate from Firebase Console → Project Settings → Service Accounts.
FIREBASE_SERVICE_ACCOUNT_JSON=""

# === Build flag — set in CI when deploying to GitHub Pages ===
GITHUB_PAGES=""
