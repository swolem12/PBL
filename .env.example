# === Firebase (client SDK — baked into the build; safe public Web config) ===
# Project: https://console.firebase.google.com/project/pickleballleague
# Fill in from Firebase Console → Project Settings → General → Your apps (Web).
NEXT_PUBLIC_FIREBASE_API_KEY=""
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN="pickleballleague.firebaseapp.com"
NEXT_PUBLIC_FIREBASE_PROJECT_ID="pickleballleague"
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET="pickleballleague.appspot.com"
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=""
NEXT_PUBLIC_FIREBASE_APP_ID=""

# === Admin seed script only — NEVER commit. Paste the JSON service account. ===
# Generate from Firebase Console → Project Settings → Service Accounts.
FIREBASE_SERVICE_ACCOUNT_JSON=""

# === Build flag — set in CI when deploying to GitHub Pages ===
GITHUB_PAGES=""
