rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Player profile photos — only the owning user can write; anyone can read.
    match /players/{uid}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.auth.uid == uid
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // Club logos (approved clubs use clubId path; pending use pending/{uid} path).
    // Write is allowed for any authenticated user — director-only access is
    // enforced at the application level (canManage check in ClubManageClient).
    match /clubs/{rest=**} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }
  }
}
