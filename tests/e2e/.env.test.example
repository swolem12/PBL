# Copy this file to .env.test and fill in real values.
# .env.test is gitignored — never commit credentials.

# ── Application ────────────────────────────────────────────
BASE_URL=http://localhost:3000
HEADLESS=true
SLOW_MO=0
BROWSER=chromium          # chromium | firefox | webkit

# ── Timeouts (ms) ──────────────────────────────────────────
DEFAULT_TIMEOUT=10000
NAV_TIMEOUT=30000

# ── Test account credentials ───────────────────────────────
# These accounts must exist in Firebase Auth (real or emulator).
# Run `npm run seed:test` to create them in the emulator.

TEST_PLAYER_EMAIL=test.player@pbl-arena.test
TEST_PLAYER_PASSWORD=TestPlayer123!

TEST_COORDINATOR_EMAIL=test.coordinator@pbl-arena.test
TEST_COORDINATOR_PASSWORD=TestCoord123!

TEST_DIRECTOR_EMAIL=test.director@pbl-arena.test
TEST_DIRECTOR_PASSWORD=TestDir123!

TEST_ADMIN_EMAIL=test.admin@pbl-arena.test
TEST_ADMIN_PASSWORD=TestAdmin123!

# ── Firebase Emulator (optional) ───────────────────────────
USE_FIREBASE_EMULATOR=false
FIREBASE_AUTH_EMULATOR_URL=http://localhost:9099

# ── Artifacts ──────────────────────────────────────────────
RECORD_VIDEO=false   # Set to true to record MP4 of each test
