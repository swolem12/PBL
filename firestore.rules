rules_version = '2';

// Pickleball League — Firestore security rules.
//
// Self-service mode: signed-in users can register for tournaments and
// report match scores. Destructive actions (delete) require staff claim.

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() { return request.auth != null; }

    // Role checks via users/{uid}.role (set during signup/profile updates).
    // userRoles docs use auto-generated IDs so cannot be path-looked-up in rules.
    function userRole() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid))
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role
        : null;
    }
    function isSiteAdmin() {
      return isSignedIn() && userRole() == "SITE_ADMIN";
    }
    function isClubDirector() {
      return isSignedIn() && userRole() in ["SITE_ADMIN", "CLUB_ADMIN"];
    }

    // Legacy helpers — map to new role model so existing rules keep working.
    function isStaff() { return isSiteAdmin() || isClubDirector(); }
    function isAdmin() { return isSiteAdmin(); }

    function isSelf(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    function isTournamentCreator(tournamentId) {
      return isSignedIn() &&
        get(/databases/$(database)/documents/tournaments/$(tournamentId)).data.createdBy == request.auth.uid;
    }

    // --- Public read, signed-in write (bootstrap) ---
    match /organizations/{doc=**} { allow read: if true; allow write: if isSignedIn(); }
    match /venues/{doc=**}        { allow read: if true; allow write: if isSignedIn(); }
    match /courts/{doc=**}        { allow read: if true; allow write: if isSignedIn(); }
    match /leagues/{doc=**}       { allow read: if true; allow write: if isSignedIn(); }
    match /seasons/{doc=**}       { allow read: if true; allow write: if isSignedIn(); }
    match /divisions/{doc=**}     { allow read: if true; allow write: if isSignedIn(); }

    match /tournaments/{id} {
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.createdBy == request.auth.uid;
      allow update: if isSignedIn() && (resource.data.createdBy == request.auth.uid || isStaff());
      allow delete: if isAdmin();
    }

    // Brackets + nodes: only the tournament creator or staff can write.
    match /brackets/{id} {
      allow read: if true;
      allow write: if isSignedIn() &&
        (isStaff() ||
         isTournamentCreator(request.resource.data.tournamentId) ||
         isTournamentCreator(resource.data.tournamentId));
    }
    match /bracketNodes/{id} {
      allow read: if true;
      allow write: if isSignedIn() &&
        (isStaff() ||
         isTournamentCreator(request.resource.data.tournamentId) ||
         isTournamentCreator(resource.data.tournamentId));
    }

    // Matches: participants OR tournament creator can update.
    // Participants are inferred via their registration's userId (client holds
    // registrationId; we keep this permissive because we validate via
    // validateMatchScore on the client). Creator/staff can always write.
    match /matches/{id} {
      allow read: if true;
      allow create: if isSignedIn() &&
        (isStaff() ||
         isTournamentCreator(request.resource.data.tournamentId));
      allow update, delete: if isSignedIn() &&
        (isStaff() ||
         isTournamentCreator(resource.data.tournamentId) ||
         // allow score-only updates by anyone signed in for now
         (request.resource.data.keys().hasOnly([
            "status", "completedAt", "winnerId", "updatedAt",
            "participantAId", "participantBId",
            "targetPoints", "winBy", "bestOf",
            "scheduledAt", "courtId", "tournamentId", "bracketNodeId", "startedAt"
          ])));
    }

    match /matchGames/{id} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /standings/{doc=**}     { allow read: if true; allow write: if isStaff() || isAdmin(); }
    match /achievements/{doc=**}  { allow read: if true; allow write: if isSignedIn(); }
    match /announcements/{doc=**} { allow read: if true; allow write: if isSignedIn(); }
    match /trophies/{doc=**}      { allow read: if true; allow write: if isSignedIn(); }

    match /users/{userId} {
      allow read: if true;
      allow create, update: if isSelf(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    match /registrations/{id} {
      allow read: if true;
      // Users register themselves; userId in payload must match auth uid.
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      // Self-withdraw OR tournament creator moderates.
      allow update: if isSignedIn() && (
        resource.data.userId == request.auth.uid ||
        isTournamentCreator(resource.data.tournamentId) ||
        isStaff()
      );
      allow delete: if isSignedIn() && (
        resource.data.userId == request.auth.uid || isStaff()
      );
    }

    match /teams/{id} {
      allow read: if true;
      allow create, update, delete: if isSignedIn();
    }

    // Private per-user notifications. Read by recipient; create by anyone signed in.
    match /notifications/{id} {
      allow read, update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn();
    }

    match /playerAchievements/{id} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /auditLog/{id} {
      allow read: if isAdmin();
      allow create: if isSignedIn();
      allow update, delete: if false;
    }

    // ========== Ladder League (spec v4) ==========
    // `seasons` and `venues` already readable above. Admin writes only.
    match /playDates/{id} {
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.createdBy == request.auth.uid;
      allow update: if isSignedIn() && (resource.data.createdBy == request.auth.uid || isStaff());
      allow delete: if isAdmin();
    }
    match /ladderSessions/{id} {
      allow read: if true;
      allow write: if isSignedIn();
    }
    match /ladderCourts/{id} {
      allow read: if true;
      allow write: if isSignedIn();
    }
    match /ladderMatches/{id} {
      allow read: if true;
      allow write: if isSignedIn();
    }
    match /checkIns/{id} {
      allow read: if true;
      // Self-check-in; the id is `${playDateId}__${userId}` and userId must match auth.
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() && (
        resource.data.userId == request.auth.uid || isStaff()
      );
      allow delete: if isStaff();
    }
    match /standingsSnapshots/{id} {
      allow read: if true;
      allow write: if isStaff() || isAdmin();
    }
    match /audits/{id} {
      allow read: if isAdmin();
      allow create: if isSignedIn();
      allow update, delete: if false;
    }

    // ========== Player profiles + ELO ==========
    // Player doc id == Firebase Auth uid. Anyone signed in (or any caller,
    // for public profile reads) may read. Only the owner may write the
    // editable identity fields; ELO / stats are updated by server-side
    // match flows (writes allowed for any signed-in user because the
    // computation is validated client-side via validateMatchScore and
    // applyMatchEloDeltas — to be tightened when Cloud Functions land).
    match /players/{uid} {
      allow read: if true;
      allow create: if isSignedIn() && request.auth.uid == uid
        && request.resource.data.userId == uid;
      allow update: if isSignedIn() && (
        request.auth.uid == uid || isStaff() ||
        // allow ELO/stat writes from any signed-in user (match-flow writes).
        request.resource.data.keys().hasOnly([
          "elo", "eloPeak",
          "stats", "stats.matches", "stats.wins", "stats.losses",
          "stats.pointsFor", "stats.pointsAgainst", "stats.updatedAt",
          "updatedAt"
        ])
      );
      allow delete: if isAdmin();
    }
    match /eloEvents/{id} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if false;
    }

    // ========== RBAC Collections ==========

    // clubs: public read; creation requires signed-in (submitClubCreation uses
    // writeBatch — the userRoles doc is written in the same batch).
    // Update: only the club's creator or a SiteAdmin.
    // Delete: SiteAdmin only.
    match /clubs/{clubId} {
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.createdBy == request.auth.uid;
      allow update: if isSignedIn() && (
        resource.data.createdBy == request.auth.uid || isSiteAdmin()
      );
      allow delete: if isSiteAdmin();
    }

    // userRoles: owner reads their own roles; SiteAdmin reads/writes all.
    // Any signed-in user can create a role doc for themselves (batch write from
    // submitClubCreation). Deactivation (update) only via SiteAdmin or self.
    match /userRoles/{roleDocId} {
      allow read: if isSignedIn() && (
        resource.data.userId == request.auth.uid || isSiteAdmin()
      );
      allow create: if isSignedIn() && (
        request.resource.data.userId == request.auth.uid || isSiteAdmin()
      );
      allow update: if isSignedIn() && (
        resource.data.userId == request.auth.uid || isSiteAdmin()
      );
      allow delete: if isSiteAdmin();
    }

    // leagueMemberships: read by owner or SiteAdmin/ClubDirector; write by staff.
    match /leagueMemberships/{id} {
      allow read: if isSignedIn() && (
        resource.data.userId == request.auth.uid || isStaff()
      );
      allow create, update: if isSignedIn() && (
        request.resource.data.userId == request.auth.uid || isStaff()
      );
      allow delete: if isStaff();
    }

    // roleEvents: immutable audit log. Anyone signed in can append; no updates/deletes.
    match /roleEvents/{id} {
      allow read: if isSignedIn() && (
        resource.data.actorId == request.auth.uid ||
        resource.data.targetUserId == request.auth.uid ||
        isSiteAdmin()
      );
      allow create: if isSignedIn();
      allow update, delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
