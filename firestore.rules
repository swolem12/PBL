rules_version = '2';

// Pickleball League — Firestore security rules.
//
// Bootstrap mode: any signed-in user can create league content. Once an
// OWNER/ADMIN custom claim is set on a user (via Admin SDK), tighten by
// swapping isSignedIn() for isStaff()/isAdmin() on write rules.

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() { return request.auth != null; }
    function isStaff() {
      return isSignedIn() && request.auth.token.role in [
        "REFEREE", "DIRECTOR", "ADMIN", "OWNER"
      ];
    }
    function isAdmin() {
      return isSignedIn() && request.auth.token.role in ["ADMIN", "OWNER"];
    }
    function isSelf(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- Public read, signed-in write (bootstrap) ---
    match /organizations/{doc=**} { allow read: if true; allow write: if isSignedIn(); }
    match /venues/{doc=**}        { allow read: if true; allow write: if isSignedIn(); }
    match /courts/{doc=**}        { allow read: if true; allow write: if isSignedIn(); }
    match /leagues/{doc=**}       { allow read: if true; allow write: if isSignedIn(); }
    match /seasons/{doc=**}       { allow read: if true; allow write: if isSignedIn(); }
    match /divisions/{doc=**}     { allow read: if true; allow write: if isSignedIn(); }
    match /tournaments/{doc=**}   { allow read: if true; allow write: if isSignedIn(); }
    match /brackets/{doc=**}      { allow read: if true; allow write: if isSignedIn(); }
    match /bracketNodes/{doc=**}  { allow read: if true; allow write: if isSignedIn(); }
    match /matches/{doc=**}       { allow read: if true; allow write: if isSignedIn(); }
    match /matchGames/{doc=**}    { allow read: if true; allow write: if isSignedIn(); }
    match /standings/{doc=**}     { allow read: if true; allow write: if isStaff() || isAdmin(); }
    match /achievements/{doc=**}  { allow read: if true; allow write: if isSignedIn(); }
    match /announcements/{doc=**} { allow read: if true; allow write: if isSignedIn(); }
    match /trophies/{doc=**}      { allow read: if true; allow write: if isSignedIn(); }

    match /users/{userId} {
      allow read: if true;
      allow create, update: if isSelf(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    match /registrations/{id} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    match /teams/{id} {
      allow read: if true;
      allow create, update, delete: if isSignedIn();
    }

    // Private per-user notifications. Read by recipient; create by anyone signed in.
    match /notifications/{id} {
      allow read, update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn();
    }

    match /playerAchievements/{id} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /auditLog/{id} {
      allow read: if isAdmin();
      allow create: if isSignedIn();
      allow update, delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
