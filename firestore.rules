rules_version = '2';

// Pickleball League - Firestore security rules.
//
// Role checks fall back to the Firestore users/{uid}.role field when no
// Firebase Auth custom claim is set. The isSiteAdmin() helper has always had
// this fallback; isClubDirector() and isLeagueCoordinator() now do too so
// Club Directors and Coordinators can write leagues, venues, and play dates
// from the client without requiring custom claims to be deployed first.

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isSelf(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function userRole() {
      // Read the Firestore role field — used as fallback when custom claims absent.
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isSiteAdmin() {
      return isSignedIn() && (
        request.auth.token.role == "SITE_ADMIN" ||
        userRole() == "SITE_ADMIN"
      );
    }

    function isClubDirector() {
      return isSignedIn() && (
        request.auth.token.role == "SITE_ADMIN" ||
        request.auth.token.role == "CLUB_ADMIN" ||
        userRole() == "SITE_ADMIN" ||
        userRole() == "CLUB_ADMIN"
      );
    }

    function isLeagueCoordinator() {
      return isSignedIn() && (
        request.auth.token.role == "SITE_ADMIN" ||
        request.auth.token.role == "CLUB_ADMIN" ||
        request.auth.token.role == "LEAGUE_COORDINATOR" ||
        userRole() == "SITE_ADMIN" ||
        userRole() == "CLUB_ADMIN" ||
        userRole() == "LEAGUE_COORDINATOR"
      );
    }

    function isStaff() {
      return isSiteAdmin() || isClubDirector() || isLeagueCoordinator();
    }

    function isAdmin() {
      return isSiteAdmin();
    }

    function isTournamentCreator(tournamentId) {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/tournaments/$(tournamentId)) &&
        get(/databases/$(database)/documents/tournaments/$(tournamentId)).data.createdBy == request.auth.uid;
    }

    function changedKeys() {
      return request.resource.data.diff(resource.data).affectedKeys();
    }

    function hasOnlyChanged(keys) {
      return changedKeys().hasOnly(keys);
    }

    function userCreateKeys() {
      return [
        "uid", "email", "firstName", "lastName", "displayName",
        "phoneNumber", "photoURL", "role", "accountStatus",
        "clubId", "leagueIds", "startingSkillRating",
        "createdAt", "updatedAt"
      ];
    }

    function userUpdateKeys() {
      return [
        "firstName", "lastName", "displayName", "phoneNumber",
        "photoURL", "startingSkillRating", "updatedAt"
      ];
    }

    function isSafeUserCreate(userId) {
      return isSelf(userId)
        && request.resource.data.keys().hasOnly(userCreateKeys())
        && (!("uid" in request.resource.data) || request.resource.data.uid == userId)
        && (!("role" in request.resource.data) || request.resource.data.role == "PLAYER")
        && (!("accountStatus" in request.resource.data) || request.resource.data.accountStatus == "ACTIVE")
        && (!("clubId" in request.resource.data) || request.resource.data.clubId == null)
        && (!("leagueIds" in request.resource.data) || request.resource.data.leagueIds.size() == 0);
    }

    function isSafeUserUpdate(userId) {
      return isSelf(userId) && hasOnlyChanged(userUpdateKeys());
    }

    function playerProfileKeys() {
      return [
        "userId", "displayName", "photoURL", "city", "region", "country",
        "homeVenueId", "homeVenueName", "dominantHand", "paddleBrand",
        "paddleModel", "yearsPlaying", "bio", "duprRating", "duprId",
        "elo", "eloPeak", "stats", "createdAt", "updatedAt"
      ];
    }

    function playerUpdateKeys() {
      return [
        "displayName", "photoURL", "city", "region", "country",
        "homeVenueId", "homeVenueName", "dominantHand", "paddleBrand",
        "paddleModel", "yearsPlaying", "bio", "duprRating", "duprId",
        "updatedAt"
      ];
    }

    function isSafePlayerCreate(uid) {
      return isSelf(uid)
        && request.resource.data.userId == uid
        && request.resource.data.keys().hasOnly(playerProfileKeys())
        && (!("elo" in request.resource.data) || request.resource.data.elo == 1500)
        && (!("eloPeak" in request.resource.data) || request.resource.data.eloPeak == 1500);
    }

    function isSafePlayerUpdate(uid) {
      return isSelf(uid) && hasOnlyChanged(playerUpdateKeys());
    }

    function keepsCreatedBy() {
      return !changedKeys().hasAny(["createdBy"]);
    }

    // Public catalog reads remain for Phase 01. Privacy hardening is Phase 04.
    match /organizations/{doc=**} { allow read: if true; allow write: if isStaff(); }
    match /venues/{doc=**}        { allow read: if true; allow write: if isStaff(); }
    match /courts/{doc=**}        { allow read: if true; allow write: if isStaff(); }
    match /leagues/{doc=**}       { allow read: if true; allow write: if isStaff(); }
    match /seasons/{doc=**}       { allow read: if true; allow write: if isStaff(); }
    match /divisions/{doc=**}     { allow read: if true; allow write: if isStaff(); }

    // Club facility information managed by Club Directors.
    match /clubFacilities/{facilityId} {
      allow read: if true;
      allow create: if isStaff();
      allow update: if isStaff();
      allow delete: if isStaff();
    }

    // Club followers — any signed-in player can follow/unfollow; anyone can read.
    match /clubFollowers/{followId} {
      allow read: if true;
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid;
      allow delete: if isSignedIn()
        && resource.data.userId == request.auth.uid;
      allow update: if false;
    }

    match /tournaments/{id} {
      allow read: if true;
      allow create: if isSignedIn()
        && request.resource.data.createdBy == request.auth.uid;
      allow update: if (isStaff() || isTournamentCreator(id)) && keepsCreatedBy();
      allow delete: if isAdmin();
    }

    match /brackets/{id} {
      allow read: if true;
      allow create: if isStaff()
        || isTournamentCreator(request.resource.data.tournamentId);
      allow update: if isStaff()
        || isTournamentCreator(resource.data.tournamentId);
      allow delete: if isAdmin();
    }

    match /bracketNodes/{id} {
      allow read: if true;
      allow create: if isStaff()
        || isTournamentCreator(request.resource.data.tournamentId);
      allow update: if isStaff()
        || isTournamentCreator(resource.data.tournamentId);
      allow delete: if isAdmin();
    }

    match /matches/{id} {
      allow read: if true;
      allow create: if isStaff()
        || isTournamentCreator(request.resource.data.tournamentId);
      allow update: if isStaff()
        || isTournamentCreator(resource.data.tournamentId);
      allow delete: if isAdmin();
    }

    match /matchGames/{id} {
      allow read: if true;
      allow write: if isStaff();
    }

    match /standings/{doc=**} {
      allow read: if true;
      allow write: if isStaff();
    }

    match /achievements/{doc=**} {
      allow read: if true;
      allow write: if isStaff();
    }

    match /announcements/{doc=**} {
      allow read: if true;
      allow write: if isStaff();
    }

    match /trophies/{doc=**} {
      allow read: if true;
      allow write: if isStaff();
    }

    match /users/{userId} {
      allow read: if true;
      allow create: if isSafeUserCreate(userId) || isAdmin();
      allow update: if isSafeUserUpdate(userId)
        || isAdmin()
        // Club directors may promote a PLAYER to LEAGUE_COORDINATOR so that
        // the assigned coordinator is recognised by Firestore security rules
        // when they perform writes (isLeagueCoordinator() checks userRole()).
        || (isClubDirector()
          && hasOnlyChanged(["role", "updatedAt"])
          && request.resource.data.role == "LEAGUE_COORDINATOR"
          && (resource.data.role == "PLAYER" || resource.data.role == "LEAGUE_COORDINATOR"));
      allow delete: if isAdmin();
    }

    match /registrations/{id} {
      allow read: if true;
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid;
      allow update: if (
        (isSignedIn() && resource.data.userId == request.auth.uid
          && hasOnlyChanged(["status", "updatedAt"]))
        || isStaff()
        || isTournamentCreator(resource.data.tournamentId)
      );
      allow delete: if isStaff();
    }

    match /teams/{id} {
      allow read: if true;
      allow create: if isSignedIn()
        && request.resource.data.createdBy == request.auth.uid;
      allow update: if isStaff()
        || (isSignedIn() && resource.data.createdBy == request.auth.uid && keepsCreatedBy());
      allow delete: if isStaff();
    }

    match /notifications/{id} {
      allow read, update, delete: if isSignedIn()
        && resource.data.userId == request.auth.uid;
      allow create: if isStaff()
        // Players can notify other players of events they triggered
        || (isSignedIn()
            && request.resource.data.createdBy == request.auth.uid
            && request.resource.data.kind in [
              "SCORE_SUBMITTED", "SCORE_DISPUTED",
              "CHALLENGE"   // player-to-player challenge events
            ]);
    }

    // Player-to-player follow relationships.
    match /playerFollows/{followId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.followerId == request.auth.uid;
      allow delete: if isSignedIn()
        && resource.data.followerId == request.auth.uid;
      allow update: if false;
    }

    // Player-to-player challenge matches.
    match /playerChallenges/{challengeId} {
      // Only the two players involved may read the challenge.
      allow read: if isSignedIn()
        && (resource.data.challengerId == request.auth.uid
            || resource.data.challengeeId == request.auth.uid)
        || isAdmin();
      // Any signed-in player can create a challenge as the challenger.
      allow create: if isSignedIn()
        && request.resource.data.challengerId == request.auth.uid
        && request.resource.data.status == "PENDING";
      // Either player may update the challenge (accept, conditions, score, verify).
      allow update: if isSignedIn()
        && (resource.data.challengerId == request.auth.uid
            || resource.data.challengeeId == request.auth.uid);
      allow delete: if isAdmin();
    }

    match /playerAchievements/{id} {
      allow read: if true;
      allow write: if isStaff();
    }

    match /auditLog/{id} {
      allow read: if isAdmin();
      allow create: if isAdmin();
      allow update, delete: if false;
    }

    match /playDates/{id} {
      allow read: if true;
      allow create: if isStaff()
        || (isSignedIn() && request.resource.data.createdBy == request.auth.uid);
      allow update: if (isStaff()
        || (isSignedIn() && resource.data.createdBy == request.auth.uid))
        && keepsCreatedBy();
      allow delete: if isAdmin();
    }

    match /ladderSessions/{id} {
      allow read: if true;
      allow write: if isStaff();
    }

    match /ladderCourts/{id} {
      allow read: if true;
      allow write: if isStaff();
    }

    match /ladderMatches/{id} {
      allow read: if true;
      allow create: if isStaff();
      allow delete: if isStaff();
      allow update: if isStaff()
        // Players can submit their own score as a match participant
        || (isSignedIn()
            && (request.auth.uid in resource.data.sideA || request.auth.uid in resource.data.sideB)
            && hasOnlyChanged(["scoreA", "scoreB", "submittedBy", "submittedAt"]))
        // Players can verify an opposing team's submission
        || (isSignedIn()
            && (request.auth.uid in resource.data.sideA || request.auth.uid in resource.data.sideB)
            && hasOnlyChanged(["verifiedBy", "verifiedAt", "status"])
            && request.resource.data.status == "VERIFIED")
        // Players can dispute a score as a match participant
        || (isSignedIn()
            && (request.auth.uid in resource.data.sideA || request.auth.uid in resource.data.sideB)
            && hasOnlyChanged(["status", "disputedBy", "disputedAt", "disputeReason"])
            && request.resource.data.status == "DISPUTED");
    }

    match /checkIns/{id} {
      allow read: if true;
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid;
      allow update: if isStaff();
      allow delete: if isStaff();
    }

    match /standingsSnapshots/{id} {
      allow read: if true;
      allow write: if isStaff();
    }

    match /audits/{id} {
      allow read: if isAdmin();
      allow create: if isStaff()
        // Players can create audit entries for their own actions
        || (isSignedIn() && request.resource.data.actorId == request.auth.uid);
      allow update, delete: if false;
    }

    match /players/{uid} {
      // Player profiles are private — require authentication to view.
      allow read: if isSignedIn();
      allow create: if isSafePlayerCreate(uid) || isAdmin();
      allow update: if isSafePlayerUpdate(uid) || isAdmin()
        // Any signed-in player may write ELO + stats fields (computed client-side
        // by applyMatchEloByUserIds after a verified challenge or ladder match).
        || (isSignedIn() && hasOnlyChanged(["elo", "eloPeak", "stats", "updatedAt"]));
      allow delete: if isAdmin();
    }

    match /eloEvents/{id} {
      allow read: if true;
      // Any signed-in player may create ELO event records (written by client-side ELO logic).
      allow create: if isSignedIn();
      allow update, delete: if false;
    }

    match /clubs/{clubId} {
      allow read: if true;
      allow create: if isSignedIn()
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.status == "pending";
      allow update: if isAdmin()
        || (isSignedIn()
          && resource.data.createdBy == request.auth.uid
          && resource.data.status == "pending"
          && request.resource.data.status == "pending"
          && keepsCreatedBy())
        // Any signed-in user may follow or unfollow a club (only followerIds changes).
        || (isSignedIn() && hasOnlyChanged(["followerIds"]));
      allow delete: if isAdmin();
    }

    match /userRoles/{roleDocId} {
      // Public read — coordinator listings appear on public club pages; data contains
      // only userId + roleId, not sensitive.
      allow read: if true;
      // Only admins / club directors can create/modify role assignments.
      allow create, update, delete: if isAdmin()
        || isClubDirector();
    }

    match /leagueMemberships/{id} {
      // Public read — player-count aggregation appears on public league/club pages.
      allow read: if true;
      // Signed-in user can join their own league (userId must be their uid, status active or waitlisted).
      allow create: if isStaff()
        || (isSignedIn()
          && request.resource.data.userId == request.auth.uid
          && request.resource.data.status in ["active", "waitlisted"]);
      // Signed-in user can leave (status → inactive) or rejoin (inactive → active, updating joinedAt).
      allow update: if isStaff()
        || (isSignedIn()
          && resource.data.userId == request.auth.uid
          && (
            // Leave: only status changes, must go to "inactive"
            (hasOnlyChanged(["status"]) && request.resource.data.status == "inactive")
            // Rejoin: status + joinedAt change, only from "inactive" → "active"
            || (hasOnlyChanged(["status", "joinedAt"])
                && resource.data.status == "inactive"
                && request.resource.data.status == "active")
          ));
      allow delete: if isStaff();
    }

    match /clubPosts/{postId} {
      allow read: if true;
      // Club directors (users/{uid}.role == CLUB_ADMIN) may post; authorId must match the caller.
      allow create: if isClubDirector()
        && request.resource.data.authorId == request.auth.uid;
      allow update: if isClubDirector()
        && resource.data.authorId == request.auth.uid;
      allow delete: if isAdmin()
        || (isClubDirector() && resource.data.authorId == request.auth.uid);
    }

    match /roleEvents/{id} {
      allow read: if isAdmin()
        || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isAdmin();
      allow update, delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
