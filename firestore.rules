rules_version = '2';

// Pickleball League — Firestore security rules.
//
// Principles:
// - Public reads for competitive content (tournaments, brackets, standings,
//   announcements) so unauthenticated visitors can browse the platform.
// - Writes are locked behind role claims (custom claims set server-side).
// - Players can only mutate their own profile / their own registrations.
// - Admin/director roles gate destructive operations.
//
// Custom claims expected (set via Cloud Functions or Admin SDK):
//   role: "PLAYER" | "TEAM_CAPTAIN" | "REFEREE" | "DIRECTOR" | "ADMIN" | "OWNER"

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() { return request.auth != null; }
    function hasRole(role) {
      return isSignedIn() && request.auth.token.role == role;
    }
    function isStaff() {
      return isSignedIn() && request.auth.token.role in [
        "REFEREE", "DIRECTOR", "ADMIN", "OWNER"
      ];
    }
    function isAdmin() {
      return isSignedIn() && request.auth.token.role in ["ADMIN", "OWNER"];
    }
    function isSelf(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- Public, read-only competitive content ---
    match /organizations/{doc=**} { allow read: if true; allow write: if isAdmin(); }
    match /venues/{doc=**}        { allow read: if true; allow write: if isAdmin(); }
    match /courts/{doc=**}        { allow read: if true; allow write: if isStaff(); }
    match /leagues/{doc=**}       { allow read: if true; allow write: if isAdmin(); }
    match /seasons/{doc=**}       { allow read: if true; allow write: if isAdmin(); }
    match /divisions/{doc=**}     { allow read: if true; allow write: if isAdmin(); }
    match /tournaments/{doc=**}   { allow read: if true; allow write: if isStaff(); }
    match /brackets/{doc=**}      { allow read: if true; allow write: if isStaff(); }
    match /bracketNodes/{doc=**}  { allow read: if true; allow write: if isStaff(); }
    match /matches/{doc=**}       { allow read: if true; allow write: if isStaff(); }
    match /matchGames/{doc=**}    { allow read: if true; allow write: if isStaff(); }
    match /standings/{doc=**}     { allow read: if true; allow write: if isStaff(); }
    match /achievements/{doc=**}  { allow read: if true; allow write: if isAdmin(); }
    match /announcements/{doc=**} { allow read: if true; allow write: if isStaff(); }
    match /trophies/{doc=**}      { allow read: if true; allow write: if isStaff(); }

    // --- User profiles ---
    match /users/{userId} {
      allow read: if true;
      allow create: if isSelf(userId);
      allow update: if isSelf(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    // --- Registrations: owned by the registering user ---
    match /registrations/{id} {
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isStaff() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow delete: if isStaff();
    }

    // --- Teams: captain writes, members read ---
    match /teams/{id} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && (
        resource.data.captainId == request.auth.uid || isStaff()
      );
    }

    // --- Private per-user notifications ---
    match /notifications/{id} {
      allow read, update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isStaff();
    }

    // --- Player achievement unlocks ---
    match /playerAchievements/{id} {
      allow read: if true;
      allow write: if isStaff();
    }

    // --- Audit log: append-only, admin read ---
    match /auditLog/{id} {
      allow read: if isAdmin();
      allow create: if isStaff();
      allow update, delete: if false;
    }

    // Anything else is denied by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
